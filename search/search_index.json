{"config":{"lang":["zh","en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6211\u7684\u6280\u672f\u7b14\u8bb0","text":"<p>\u6b22\u8fce\u6765\u5230\u6211\u7684\u77e5\u8bc6\u5e93\uff01\u8fd9\u91cc\u8bb0\u5f55\u4e86\u6211\u5b66\u4e60\u7f16\u7a0b\u8fc7\u7a0b\u4e2d\u7684\u7b14\u8bb0\u548c\u5fc3\u5f97\u3002</p>"},{"location":"#_2","title":"\ud83d\udcda \u5feb\u901f\u5bfc\u822a","text":"<ul> <li>MySQL\u5b66\u4e60\u7b14\u8bb0</li> </ul> <p>\u4f7f\u7528\u53f3\u4e0a\u89d2\u7684\u641c\u7d22\u6846\u53ef\u4ee5\u5feb\u901f\u627e\u5230\u4efb\u4f55\u5185\u5bb9\uff01</p>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/","title":"MySQL\u5b66\u4e60\u7b14\u8bb0","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#_1","title":"\ud83d\udcda \u5feb\u901f\u5bfc\u822a","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#3_2","title":"3_2 \u5b66\u4e60\u7b14\u8bb0","text":"<ul> <li>\u4e00\u3001\u7d22\u5f15\u4f7f\u7528\u89c4\u5219</li> <li>\u4e8c\u3001\u7d22\u5f15\u8bbe\u8ba1\u539f\u5219</li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#3_3","title":"3_3 \u5b66\u4e60\u7b14\u8bb0","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/","title":"3_2","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#_1","title":"\u76ee\u5f55","text":"<ul> <li>\u4e00\u3001\u7d22\u5f15\u4f7f\u7528\u89c4\u5219</li> <li>\u4e8c\u3001\u7d22\u5f15\u8bbe\u8ba1\u539f\u5219</li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#_2","title":"\u7d22\u5f15\u4f7f\u7528\u89c4\u5219","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#1","title":"1. \u9a8c\u8bc1\u7d22\u5f15\u6548\u7387","text":"<pre><code>select * from tb_user\\G;\n</code></pre> <p>\u8fd9\u91cc\\G\u7684\u4f5c\u7528\u662f\u5c06\u5185\u5bb9\u4ee5\u5217\u8868\u7684\u5f62\u5f0f\u5c55\u793a\u51fa\u6765</p> <ul> <li>\u9488\u5bf9\u5b57\u6bb5\u521b\u5efa\u7d22\u5f15</li> </ul> <pre><code>create [UNIQUE|FULLTEXT] index index_name on table_name(index_col_name,...);\n</code></pre> <p>\u4e00\u4e2a\u7d22\u5f15\u53ef\u4ee5\u5173\u8054\u591a\u4e2a\u5b57\u6bb5,\u5b57\u6bb5\u4e4b\u95f4\u7684\u987a\u5e8f\u6709\u5f71\u54cd\uff0c\u53c2\u8003\u6700\u5de6\u524d\u7f00\u6cd5\u5219</p> <ul> <li>\u67e5\u770b\u7d22\u5f15</li> </ul> <pre><code>SHOW INDEX FROM table_name;\n</code></pre> <ul> <li>\u5220\u9664\u7d22\u5f15</li> </ul> <pre><code>DROP INDEX index_name ON table_name;\n</code></pre>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#2","title":"2. \u6700\u5de6\u524d\u7f00\u6cd5\u5219","text":"<p>\u5982\u679c\u7d22\u5f15\u4e86\u591a\u5217\uff08\u8054\u5408\u7d22\u5f15\uff09\uff0c\u8981\u9075\u5b88\u6700\u5de6\u524d\u7f00\u6cd5\u5219\u3002\u6700\u5de6\u524d\u7f00\u6cd5\u5219\u6307\u7684\u662f\u67e5\u8be2\u4ece\u7d22\u5f15\u7684\u6700\u5de6\u5217\u5f00\u59cb\uff0c\u5e76\u4e14\u4e0d\u8df3\u8fc7\u7d22\u5f15\u4e2d\u7684\u5217\u3002\u5982\u679c\u8df3\u8dc3\u67d0\u4e00\u5217\uff0c==\u7d22\u5f15\u5c06\u90e8\u5206\u5931\u6548\uff08\u540e\u9762\u7684\u5b57\u6bb5\u7d22\u5f15\u5931\u6548\uff09==\u3002</p> <ul> <li>\u8303\u56f4\u67e5\u8be2\uff1a\u8054\u5408\u7d22\u5f15\u4e2d\uff0c\u51fa\u73b0\u8303\u56f4\u67e5\u8be2\uff08&gt;,&lt;\uff09,==\u8303\u56f4\u67e5\u8be2\u53f3\u4fa7\u7684\u5217\u7d22\u5f15\u5931\u6548==\u3002\uff08\u7528&gt;=,&lt;=\u5219\u4e0d\u4f1a\u5931\u6548\uff09</li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#3","title":"3. \u7d22\u5f15\u5217\u5931\u6548\u60c5\u51b5\u4e00","text":"<ol> <li> <p>\u7d22\u5f15\u5217\u8fd0\u7b97\uff1a\u4e0d\u8981\u5728\u7d22\u5f15\u5217\u4e0a\u8fdb\u884c\u8fd0\u7b97\u64cd\u4f5c\uff0c\u7d22\u5f15\u5c06\u5931\u6548\u3002</p> <ul> <li>\u622a\u53d6\u5b57\u6bb5\uff1a<code>select * from tb_user where substring(phone,10,2) = '15';</code> \u8fd9\u91ccphone\u5b57\u6bb5\u6ca1\u6709\u7528\u4e0a\uff0c\u5931\u6548\u4e86  </li> <li>type = ALL \u5373\u4e3a\u5168\u8868\u626b\u63cf</li> </ul> </li> <li> <p>\u5b57\u7b26\u4e32\u4e0d\u52a0\u5f15\u53f7\uff1a\u7d22\u5f15\u5c06\u5931\u6548\u3002 \u9690\u5f0f\u8f6c\u6362\u5c06\u4e0d\u4f1a\u751f\u6548</p> </li> <li> <p>\u6a21\u7cca\u67e5\u8be2\uff1a\u5982\u679c\u4ec5\u4ec5\u662f\u5c3e\u90e8\u6a21\u7cca\u5339\u914d\uff0c\u7d22\u5f15\u5c06\u4e0d\u4f1a\u5931\u6548\u3002\u5982\u5c06\u5934\u90e8\u6a21\u7cca\u5339\u914d\uff0c\u7d22\u5f15\u5931\u6548\u3002</p> <pre><code>explain select * from tb_user where profession like '\u8f6f\u4ef6%'; //\u4e0d\u4f1a\u5931\u6548\nexplain select * from tb_user where profession like '%\u8f6f\u4ef6';//\u4f1a\u5931\u6548\n</code></pre> </li> </ol>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#4","title":"4. \u7d22\u5f15\u5931\u6548\u60c5\u51b5\u4e8c","text":"<ol> <li> <p>or\u8fde\u63a5\u7684\u6761\u4ef6\uff1a\u7528or\u5206\u5272\u5f00\u7684\u6761\u4ef6\uff0c\u5982\u679cor\u524d\u7684\u6761\u4ef6\u4e2d\u7684\u5217\u6709\u7d22\u5f15\uff0c\u800c\u540e\u9762\u7684\u5217\u4e2d\u6ca1\u6709\u7d22\u5f15\uff0c\u90a3\u4e48\u6d89\u53ca\u7684\u7d22\u5f15\u90fd\u4e0d\u4f1a\u88ab\u7528\u5230\u3002</p> </li> <li> <p>\u6570\u636e\u5206\u5e03\u5f71\u54cd\uff1a\u5982\u679cMySQL\u8bc4\u4f30\u4f7f\u7528\u7d22\u5f15\u6bd4\u5168\u8868\u66f4\u6162\uff0c\u5219\u4e0d\u4f7f\u7528\u7d22\u5f15\u3002</p> </li> </ol>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#5-sql","title":"5. SQL\u63d0\u793a","text":"<ol> <li>use index</li> </ol> <pre><code>select * from tb_user use index(idx_user_pro) where profession = '\u8f6f\u4ef6\u5de5\u7a0b';\n</code></pre> <ol> <li>ingnore index</li> </ol> <pre><code>select * from tb_user ignore index(idx_user_pro) where profession = '\u8f6f\u4ef6\u5de5\u7a0b';\n</code></pre> <ol> <li>force index</li> </ol> <pre><code>select * from tb_user force index(idx_user_pro) where profession = '\u8f6f\u4ef6\u5de5\u7a0b';\n</code></pre>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#6","title":"6. \u8986\u76d6\u7d22\u5f15&amp;\u56de\u8868\u67e5\u8be2","text":"<p>\u5c3d\u91cf\u4f7f\u7528\u8986\u76d6\u7d22\u5f15\uff08\u67e5\u8be2\u4f7f\u7528\u4e86\u7d22\u5f15\uff0c\u5e76\u4e14\u9700\u8981\u8fd4\u56de\u7684\u5217\uff0c\u5728\u8be5\u7d22\u5f15\u4e2d\u5df2\u7ecf\u5168\u90e8\u80fd\u591f\u627e\u5230\uff09\uff0c\u51cf\u5c11select *\u3002</p> <p></p>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#7","title":"7. \u524d\u7f00\u7d22\u5f15","text":"<p>\u5f53\u5b57\u6bb5\u7c7b\u578b\u4e3a\u5b57\u7b26\u4e32\uff08varchar\uff0ctext\u7b49\uff09\u65f6\uff0c\u6709\u65f6\u5019\u9700\u8981\u7d22\u5f15\u5f88\u957f\u7684\u5b57\u7b26\u4e32\uff0c\u8fd9\u4f1a\u8ba9\u7d22\u5f15\u53d8\u5f97\u5f88\u5927\uff0c\u67e5\u8be2\u65f6\uff0c\u6d6a\u8d39\u5927\u91cf\u7684\u78c1\u76d8IO\uff0c\u5f71\u54cd\u67e5\u8be2\u6548\u7387\u3002\u6b64\u65f6\u53ef\u4ee5\u53ea\u5c06\u5b57\u7b26\u4e32\u7684\u4e00\u90e8\u5206\u524d\u7f00\uff0c\u5efa\u7acb\u7d22\u5f15\uff0c\u8fd9\u6837\u53ef\u4ee5\u5927\u5927\u8282\u7ea6\u7d22\u5f15\u7a7a\u95f4\uff0c\u4ece\u800c\u63d0\u9ad8\u7d22\u5f15\u6548\u7387\u3002</p> <ol> <li>\u8bed\u6cd5</li> </ol> <pre><code>create index idx_xxxx on table_name(column(n));//\u63d0\u53d6\u524dn\u4e2a\u5b57\u7b26\u6765\u6784\u5efa\u7d22\u5f15\n</code></pre> <ol> <li>\u524d\u7f00\u957f\u5ea6</li> </ol> <p>\u53ef\u4ee5\u6839\u636e\u7d22\u5f15\u7684\u9009\u62e9\u6027\u6765\u51b3\u5b9a\uff0c\u9009\u62e9\u6027\u6307\u7684\u662f\u4e0d\u91cd\u590d\u7684\u7d22\u5f15\u503c\uff08\u57fa\u6570\uff09\u548c\u6570\u636e\u8868\u7684\u8bb0\u5f55\u603b\u6570\u7684\u6bd4\u503c\uff0c\u7d22\u5f15\u9009\u62e9\u6027\u8d8a\u9ad8\u5219\u67e5\u8be2\u6548\u7387\u8d8a\u9ad8\uff0c\u552f\u4e00\u7d22\u5f15\u7684\u9009\u62e9\u6027\u662f1\uff0c\u8fd9\u662f\u6700\u597d\u7684\u7d22\u5f15\u9009\u62e9\u6027\uff0c\u6027\u80fd\u4e5f\u662f\u6700\u597d\u7684\u3002</p> <pre><code>select count(distinct email)/count(*) from tb_user;\nselect count(distinct substring(email,1,5))/count(*) from tb_user;\n</code></pre> <ul> <li>\u67e5\u770b\u6709\u591a\u5c11email\u4e0d\u91cd\u590d</li> </ul> <pre><code>select count(distinct email) from tb_user;\n</code></pre>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#8","title":"8. \u5355\u5217&amp;\u8054\u5408\u7d22\u5f15","text":"<ol> <li>\u5355\u5217\u7d22\u5f15\uff1a\u5373\u4e00\u4e2a\u7d22\u5f15\u53ea\u5305\u542b\u5355\u4e2a\u5217\u3002</li> <li>\u8054\u5408\u7d22\u5f15\uff1a\u5373\u4e00\u4e2a\u7d22\u5f15\u5305\u542b\u4e86\u591a\u4e2a\u5217\u3002</li> </ol> <p>\u5728\u4e1a\u52a1\u573a\u666f\u4e2d\uff0c\u5982\u679c\u5b58\u5728\u591a\u4e2a\u67e5\u8be2\u6761\u4ef6\uff0c\u8003\u8651\u9488\u5bf9\u4e8e\u67e5\u8be2\u5b57\u6bb5\u5efa\u7acb\u7d22\u5f15\u65f6\uff0c\u5efa\u8bae\u5efa\u7acb\u8054\u5408\u7d22\u5f15\uff0c\u800c\u975e\u5355\u5217\u7d22\u5f15\u3002</p> <p>==\u591a\u6761\u4ef6\u8054\u5408\u67e5\u8be2\u65f6\uff0cMySQL\u4f18\u5316\u5668\u4f1a\u8bc4\u4f30\u90a3\u4e2a\u5b57\u6bb5\u6548\u7387\u66f4\u9ad8\uff0c\u4f1a\u9009\u62e9\u8be5\u7d22\u5f15\u5b8c\u6210\u672c\u6b21\u67e5\u8be2\u3002==</p>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_2%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/#_3","title":"\u7d22\u5f15\u8bbe\u8ba1\u539f\u5219","text":"<p>\u56de\u5230\u9876\u90e8</p>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/","title":"3_3","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#sql","title":"SQL\u4f18\u5316","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#_1","title":"\u63d2\u5165\u6570\u636e","text":"<ul> <li>insert\u4f18\u5316 \u4e0d\u5efa\u8bae\u4e00\u6b21\u6027\u63d2\u51651000\u6761\u6570\u636e</li> <li>\u624b\u52a8\u63d0\u4ea4\u4e8b\u52a1</li> </ul> <pre><code>start transaction;\ninsert ...\ninsert ...\n...\ncommit;\n</code></pre> <ul> <li> <p>\u4e3b\u952e\u987a\u5e8f\u63d2\u5165   \u53d6\u51b3\u4e8eMySQL\u7684\u6570\u636e\u7ec4\u7ec7\u7ed3\u6784</p> </li> <li> <p>\u5927\u6279\u91cf\u63d2\u5165\u6570\u636e   \u9700\u8981\u4f7f\u7528load\u6307\u4ee4</p> </li> <li> <p>\u5ba2\u6237\u7aef\u8fde\u63a5\u670d\u52a1\u7aef\u65f6\uff0c\u52a0\u4e0a\u53c2\u6570--local-infile</p> <pre><code>mysql --local-infile -u root -p\n</code></pre> </li> <li> <p>\u8bbe\u7f6e\u5168\u5c40\u53c2\u6570local_infile\u4e3a1\uff0c\u5f00\u542f\u4ece\u672c\u5730\u52a0\u8f7d\u6587\u4ef6\u5bfc\u5165\u6570\u636e\u7684\u5f00\u5173</p> <pre><code>//\u67e5\u770b\u8fd9\u4e2a\u5f00\u5173\u662f\u5426\u5f00\u542f\nselect @@local_infile;\n//\u6253\u5f00\u5f00\u5173\nset global local_infile = 1;\n</code></pre> </li> <li> <p>\u6267\u884cload\u6307\u4ee4\u5c06\u51c6\u5907\u597d\u7684\u6570\u636e\uff0c\u52a0\u8f7d\u5230\u8868\u7ed3\u6784\u4e2d</p> <pre><code>load data local infile '/root/sql1.log' into table 'tb_user' fields terminated by ',' lines terminated by '/n';\n</code></pre> </li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#_2","title":"\u4e3b\u952e\u4f18\u5316","text":"<ul> <li> <p>\u6570\u636e\u7ec4\u7ec7\u65b9\u5f0f \u5728InnoDB\u5b58\u50a8\u5f15\u64ce\u4e2d\uff0c\u8868\u6570\u636e\u90fd\u662f\u6839\u636e\u4e3b\u952e\u987a\u5e8f\u7ec4\u7ec7\u5b58\u653e\u7684\uff0c\u8fd9\u79cd\u5b58\u50a8\u65b9\u5f0f\u7684\u8868\u79f0\u4e3a==\u7d22\u5f15\u7ec4\u7ec7\u8868==(index organized table ==IOT==)\u3002</p> </li> <li> <p>\u9875\u5206\u88c2 \u9875\u53ef\u4ee5\u4e3a\u7a7a\uff0c\u4e5f\u53ef\u4ee5\u586b\u5145\u4e00\u534a\uff0c\u4e5f\u53ef\u4ee5\u586b\u5145100%\u3002\u6bcf\u4e2a\u9875\u5305\u542b\u4e862~N\u884c\u6570\u636e\uff08\u5982\u679c\u4e00\u884c\u6570\u636e\u592a\u5927\uff0c\u4f1a\u884c\u6ea2\u51fa\uff09\uff0c\u6839\u636e\u4e3b\u952e\u6392\u5217\u3002</p> </li> </ul> <p> </p> <ul> <li>\u9875\u5408\u5e76 \u5f53\u5220\u9664\u4e00\u884c\u8bb0\u5f55\u65f6\uff0c\u5b9e\u9645\u4e0a\u8bb0\u5f55\u5e76\u6ca1\u6709\u88ab\u7269\u7406\u5220\u9664\uff0c\u81f3\u5c11\u8bb0\u5f55\u88ab\u6807\u8bb0\uff08flaged\uff09\u4e3a\u5220\u9664\u5e76\u4e14\u5b83\u7684\u7a7a\u95f4\u53d8\u5f97\u5141\u8bb8\u88ab\u5176\u4ed6\u8bb0\u5f55\u58f0\u660e\u4f7f\u7528\u3002 \u5f53\u9875\u4e2d\u5220\u9664\u7684\u8bb0\u5f55\u8fbe\u5230==MERGE_THRESHOLD==(\u9ed8\u8ba4\u4e3a\u9875\u768450%)\uff0cInnoDB\u4f1a\u5f00\u59cb\u5bfb\u627e\u6700\u9760\u8fd1\u7684\u9875\uff08\u524d\u6216\u540e\uff09\u770b\u770b\u662f\u5426\u53ef\u4ee5\u5c06\u4e24\u4e2a\u9875\u5408\u5e76\u5e76\u4ee5\u4f18\u5316\u7a7a\u95f4\u4f7f\u7528\u3002</li> </ul> <p>MERGE_THRESHOLD\u53ef\u4ee5\u81ea\u5df1\u8bbe\u7f6e\uff0c\u5728\u521b\u5efa\u8868\u6216\u8005\u521b\u5efa\u7d22\u5f15\u65f6\u6307\u5b9a\u3002</p> <p> </p> <ul> <li> <p>\u4e3b\u952e\u7684\u8bbe\u8ba1\u539f\u5219</p> </li> <li> <p>\u6ee1\u8db3\u4e1a\u52a1\u9700\u6c42\u7684\u60c5\u51b5\u4e0b\uff0c\u5c3d\u91cf\u964d\u4f4e\u4e3b\u952e\u7684\u957f\u5ea6\u3002</p> </li> <li>\u63d2\u5165\u6570\u636e\u65f6\uff0c\u5c3d\u91cf\u9009\u62e9\u987a\u5e8f\u63d2\u5165\uff0c\u9009\u62e9\u4f7f\u7528AUTO_INCREMENT\u81ea\u589e\u4e3b\u952e\u3002</li> <li>\u5c3d\u91cf\u4e0d\u8981\u4f7f\u7528UUID(\u901a\u7528\u552f\u4e00\u6807\u8bc6\u7b26\uff08Universally Unique Identifier\uff09)\u505a\u4e3b\u952e\uff0c\u5982\u8eab\u4efd\u8bc1\u53f7\u3002</li> <li>\u4e1a\u52a1\u64cd\u4f5c\u65f6\uff0c\u907f\u514d\u5bf9\u4e3b\u952e\u7684\u4fee\u6539\u3002</li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#order-by","title":"order by \u4f18\u5316","text":"<ol> <li>Using filesort\uff1a\u901a\u8fc7\u8868\u7684\u7d22\u5f15\u6216\u5168\u8868\u626b\u63cf\uff0c\u8bfb\u53d6\u6ee1\u8db3\u6761\u4ef6\u7684\u6570\u636e\u884c\uff0c\u7136\u540e\u5728\u6392\u5e8f\u7f13\u51b2\u533asort buffer\u5b8c\u6210\u6392\u5e8f\u64cd\u4f5c\uff0c\u6240\u4ee5\u4e0d\u662f\u901a\u8fc7\u7d22\u5f15\u76f4\u63a5\u8fd4\u56de\u6392\u5e8f\u7ed3\u679c\u7684\u6392\u5e8f\u90fd\u53ebFileSort\u6392\u5e8f\u3002</li> <li> <p>Using index\uff1a\u901a\u8fc7\u6709\u5e8f\u7d22\u5f15\u987a\u5e8f\u626b\u63cf\u76f4\u63a5\u8fd4\u56de\u6709\u5e8f\u6570\u636e\uff0c\u8fd9\u79cd\u60c5\u51b5\u5373\u4e3ausing index\uff0c\u4e0d\u9700\u8981\u989d\u5916\u6392\u5e8f\uff0c\u64cd\u4f5c\u6548\u7387\u9ad8\u3002</p> </li> <li> <p>\u6ca1\u6709\u521b\u5efa\u7d22\u5f15\u65f6\uff0c\u6839\u636eage\uff0cphone\u8fdb\u884c\u6392\u5e8f</p> </li> </ol> <pre><code>explain select id,age,phone from tb_user order by age,phone;\n</code></pre> <ul> <li>\u521b\u5efa\u7d22\u5f15\u540e\uff0c\u6839\u636eage\uff0cphone\u8fdb\u884c\u5347\u5e8f\u6392\u5e8f</li> </ul> <pre><code>explain selectt id,age,phone from tb_user order by age, phone;\n</code></pre> <ul> <li>\u521b\u5efa\u7d22\u5f15\u540e\uff0c\u6839\u636eage\uff0cphone\u8fdb\u884c\u964d\u5e8f\u6392\u5e8f</li> </ul> <pre><code>explain selectt id,age,phone from tb_user order by age desc, phone desc;\n</code></pre> <ul> <li>\u6839\u636eage\uff0cphone\u8fdb\u884c\u4e00\u4e2a\u5347\u5e8f\uff0c\u4e00\u4e2a\u964d\u5e8f</li> </ul> <pre><code>explain select id,age,phone from tb_user order by age asc,phone desc;\n</code></pre> <ul> <li>\u521b\u5efa\u7d22\u5f15</li> </ul> <pre><code>create index idx_user_age_ad on tb_user(age asc,phone desc);\n</code></pre> <ul> <li>\u6839\u636e\u6392\u5e8f\u5b57\u6bb5\u5efa\u7acb\u5408\u9002\u7684\u7d22\u5f15\uff0c\u591a\u5b57\u6bb5\u6392\u5e8f\u65f6\uff0c\u4e5f\u9075\u5faa\u6700\u5de6\u524d\u7f00\u6cd5\u5219\u3002</li> <li>\u5c3d\u91cf\u4f7f\u7528\u8986\u76d6\u7d22\u5f15\u3002</li> <li>\u591a\u5b57\u6bb5\u6392\u5e8f\uff0c\u4e00\u4e2a\u5347\u5e8f\u4e00\u4e2a\u964d\u5e8f\uff0c\u6b64\u65f6\u9700\u8981\u6ce8\u610f\u8054\u5408\u7d22\u5f15\u5728\u521b\u5efa\u65f6\u7684\u89c4\u5219\uff08ASC/DESC\uff09\u3002</li> <li>\u5982\u679c\u4e0d\u53ef\u907f\u514d\u51fa\u73b0filesort\uff0c\u5927\u6570\u636e\u6392\u5e8f\u65f6\uff0c\u53ef\u4ee5\u9002\u5f53\u589e\u5927\u6392\u5e8f\u7f13\u51b2\u5927\u5c0fsort_buffer_size(\u9ed8\u8ba4256k)\u3002</li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#group-by","title":"group by\u4f18\u5316","text":"<ul> <li>\u6267\u884c\u5206\u7ec4\u64cd\u4f5c\uff0c\u6839\u636eprofession\u5b57\u6bb5\u5206\u7ec4</li> </ul> <pre><code>explain select profession, count(*) from tb_user group by profession;\n</code></pre> <ul> <li>\u5728\u5206\u7ec4\u64cd\u4f5c\u65f6\uff0c\u53ef\u4ee5\u901a\u8fc7\u7d22\u5f15\u6765\u63d0\u9ad8\u6548\u7387\u3002</li> <li>\u5206\u7ec4\u64cd\u4f5c\u65f6\uff0c\u7d22\u5f15\u7684\u4f7f\u7528\u4e5f\u662f\u6ee1\u8db3\u6700\u5de6\u524d\u7f00\u6cd5\u5219\u7684\u3002</li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#limit","title":"limit\u4f18\u5316","text":"<ul> <li>\u5206\u9875\u67e5\u8be2\u7684\u4f18\u5316   \u4f18\u5316\u601d\u8def\uff1a\u4e00\u822c\u5206\u9875\u67e5\u8be2\u65f6\uff0c\u901a\u8fc7\u521b\u5efa\uff0c\u8986\u76d6\u7d22\u5f15\u80fd\u591f\u8f83\u597d\u5730\u63d0\u9ad8\u6027\u80fd\uff0c\u53ef\u4ee5\u901a\u8fc7\u8986\u76d6\u7d22\u5f15\u52a0\u5b50\u67e5\u8be2\u5f62\u5f0f\u8fdb\u884c\u4f18\u5316\u3002</li> </ul> <pre><code>explain select * from tb_user t,(select id from tb_sku order by id limit 20000000,10) a where t.id = a.id;\n</code></pre>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#count","title":"count\u4f18\u5316","text":"<ul> <li>count(\u4e3b\u952e)</li> <li>count(\u5b57\u6bb5)</li> <li>count(\u6570\u5b57)</li> <li>count(*)   </li> </ul>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#updata","title":"updata\u4f18\u5316(\u907f\u514d\u884c\u9501\u5347\u7ea7\u4e3a\u8868\u9501)","text":"<p>==InnoDB\u7684\u884c\u9501\u662f\u9488\u5bf9\u7d22\u5f15\u52a0\u7684\u9501\uff0c\u4e0d\u662f\u9488\u5bf9\u8bb0\u5f55\u52a0\u7684\u9501\uff0c\u5e76\u4e14\u8be5\u7d22\u5f15\u4e0d\u80fd\u5931\u6548\uff0c\u5426\u5219\u4f1a\u4ece\u884c\u9501\u5347\u7ea7\u4e3a\u8868\u9501\u3002==</p>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#_3","title":"\u603b\u7ed3","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#_4","title":"\u89c6\u56fe","text":""},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#_5","title":"\u4ecb\u7ecd\u548c\u57fa\u672c\u8bed\u6cd5","text":"<p>\u89c6\u56fe\u4e2d\u5e76\u4e0d\u5b58\u50a8\u6570\u636e\uff0c\u6570\u636e\u5b58\u50a8\u5728\u57fa\u8868\u5f53\u4e2d</p> <ul> <li>\u521b\u5efa</li> </ul> <pre><code>CREATE [OR REPLACE] VIEW \u89c6\u56fe\u540d\u79f0[(\u5217\u8868\u540d\u79f0)] AS SELECT\u8bed\u53e5 [WITH[CASCADED|LOCAL]CHECK OPTION]\n</code></pre> <ul> <li>\u67e5\u8be2</li> </ul> <pre><code>//\u67e5\u770b\u521b\u5efa\u89c6\u56fe\u8bed\u53e5\uff1aSHOW CREATE VIEW \u89c6\u56fe\u540d\u79f0;\n//\u67e5\u770b\u89c6\u56fe\u6570\u636e\uff1aSELECT * FROM \u89c6\u56fe\u540d\u79f0 ......;\n</code></pre> <ul> <li>\u4fee\u6539</li> </ul> <pre><code>\u65b9\u5f0f\u4e00\uff1aCREATE [OR REPLACE] VIEW \u89c6\u56fe\u540d\u79f0[(\u5217\u540d\u5217\u8868)] AS SELECT\u8bed\u53e5 [WITH[CASCADED|LOCAL] CHECK OPTION]\n\u65b9\u5f0f\u4e8c\uff1aALTER VIEW \u89c6\u56fe\u540d\u79f0[(\u5217\u540d\u5217\u8868)] AS SELECT\u8bed\u53e5 [WITH[CASCADED|LOCAL] CHECK OPTION]\n</code></pre> <ul> <li>\u5220\u9664</li> </ul> <pre><code>DROP VIEW [IF EXISTS] \u89c6\u56fe\u540d\u79f0 [,\u89c6\u56fe\u540d\u79f0] ...\n</code></pre>"},{"location":"MySQL%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/3_3/#cascaded","title":"\u68c0\u67e5\u9009\u9879\uff08cascaded\uff09","text":""},{"location":"%E5%AD%A6%E4%B9%A0%E5%8E%86%E7%A8%8B%E8%AE%B0%E5%BD%95/3_5%E5%AD%A6%E4%B9%A0%E5%BF%83%E5%BE%97/","title":"\u5173\u4e8e\u505a\u7b14\u8bb0\u7684\u60f3\u6cd5","text":"<p>\u505a\u7b14\u8bb0\u4e0d\u5e94\u8be5\u662f\u5c06\u4e66\u4e0a\u6216\u662f\u89c6\u9891\u4e2d\u7684\u5185\u5bb9\u539f\u5c01\u4e0d\u52a8\u7684\u7167\u642c\u5230\u4f60\u7684\u672c\u5b50\u6216\u7535\u8111\u4e0a\uff0c\u800c\u662f\u5c06\u4f60\u7684\u601d\u8003\uff0c\u4f60\u5bf9\u521a\u521a\u5b66\u4e60\u5185\u5bb9\u7684\u601d\u8003\uff0c\u56f0\u60d1\u548c\u89e3\u51b3\u65b9\u6848\u7ed9\u8bb0\u5f55\u4e0b\u6765\u3002</p> <p>\u6211\u4e4b\u524d\u5bf9\u4e8e\u597d\u8bb0\u6027\u4e0d\u5982\u70c2\u7b14\u5934\u7684\u770b\u6cd5\u660e\u663e\u6709\u4e86\u5f88\u5927\u7684\u8bef\u533a\uff0c\u5176\u5b9e\u505a\u7b14\u8bb0\u662f\u9632\u6b62\u672a\u6765\u6211\u4eec\u5fd8\u4e86\u4f60\u4eba\u5b66\u4e60\u8fc7\u7a0b\u4e2d\u7684\u7075\u5149\u4e00\u95ea\uff0c\u6240\u4ee5\u6211\u4eec\u628a\u5b83\u7ed9\u8bb0\u5f55\u4e0b\u6765\u3002\u6216\u8005\u8bf4\u662f\u6211\u4eec\u505a\u7b14\u8bb0\u5e94\u8be5\u662f\u62b1\u7740\u8fd9\u6837\u4e00\u79cd\u5fc3\u6001\uff1a\u6211\u662f\u5728\u521b\u4f5c\u4e00\u90e8\u4f5c\u54c1\uff0c\u8981\u6709\u8fd9\u79cd\u4f5c\u54c1\u601d\u7ef4\u3002\u4f5c\u54c1\u5e94\u8be5\u662f\u7528\u6765\u8bb0\u5f55\u4eba\u7684\u667a\u6167\u7ed3\u6676\u7684\u3002\u80fd\u88ab\u8bb0\u5f55\u4e0b\u6765\u7684\u4e1c\u897f\u90fd\u662f\u6709\u7740\u667a\u6167\u7684\uff0c\u6211\u4eec\u770b\u770b\uff0c\u90a3\u4e9b\u7cdf\u7c95\u597d\u610f\u601d\u8bb0\u5f55\u5230\u4e66\u672c\u4e0a\u5417\uff1f\u53c8\u6216\u662f\u8bf4\u6211\u4eec\u505a\u7684\u8a8a\u5199\u7684\u8fd9\u5de5\u4f5c\u4e5f\u6ca1\u6709\u610f\u4e49\u3002\u53e4\u4eba\u7684\u8bdd\u6ca1\u6709\u95ee\u9898\uff0c\u95ee\u9898\u5728\u4e8e\u6211\u4ee5\u524d\u7406\u89e3\u7684\u65b9\u5f0f\u4e0d\u5bf9\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/4_2/","title":"4_2 java\u5b66\u4e60\u7b14\u8bb0","text":""},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/4_2/#requestbody","title":"@RequestBody","text":"<p>\u662f\u4ec0\u4e48\uff1a\u628ahttp\u8bf7\u6c42Body\u91cc\u7684JSON\uff0c\u81ea\u52a8\u8f6c\u6210Java\u5bf9\u8c61 \u4e3a\u4ec0\u4e48\u9700\u8981\u5b83\uff1aPOST\u8bf7\u6c42\u7684\u6570\u636e\u4e0d\u5728URL\u91cc\uff0c\u5728Body\u91cc\uff0c\u4e0d\u7528\u5b83\u5c31\u62ff\u4e0d\u5230 \u5751\u70b9\uff1aBody\u53ea\u80fd\u8bfb\u4e00\u6b21\uff0c\u522b\u5728Filter\u91cc\u63d0\u524d\u8bfb\u6389</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/4_2/#pathvariable","title":"@PathVariable","text":"<p>\u662f\u4ec0\u4e48\uff1a\u628aURL\u8def\u5f84\u91cc\u7684{}\u5360\u4f4d\u7b26\uff0c\u62ff\u51fa\u6765\u505a\u65b9\u6cd5\u53c2\u6570 \u4e3a\u4ec0\u4e48\u9700\u8981\u5b83\uff1aGET /student/1 \u91cc\u7684\u201c1\u201d\u5728\u8def\u5f84\u91cc\uff0c\u4e0d\u5728Body\u91cc \u5751\u70b9\uff1a\u8def\u5f84\u91cc\u5fc5\u987b\u5199{}\uff0c\u4e0d\u7136Spring\u5f53\u56fa\u5b9a\u8def\u5f84\uff0c\u6c38\u8fdc\u5339\u914d\u4e0d\u5230</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/4_2/#restcontroller","title":"RestController","text":"<p>\u662f\u4ec0\u4e48\uff1a@Controller +@ResponseBody\u7684\u7ec4\u5408 @Controller\uff1a\u8ba9Spring\u8bc6\u522b\u8fd9\u4e2a\u7c7b\u662fHTTP\u8bf7\u6c42\u5904\u7406\u5668 @ResponseBody\uff1a\u628a\u65b9\u6cd5\u8fd4\u56de\u7684Java\u5bf9\u8c61\u81ea\u52a8\u8f6c\u6210JSON\u8f93\u51fa \u4e3a\u4ec0\u4e48\u9700\u8981\u5b83\uff1a\u4e0d\u7136\u8981\u5199\u4e24\u4e2a\u6ce8\u89e3\uff0c\u800c\u4e14\u8fd4\u56de\u503c\u4e0d\u4f1a\u81ea\u52a8\u53d8JSON \u5751\u70b9\uff1a\u53ea\u80fd\u52a0\u5728\u7c7b\u4e0a\uff0c\u65b9\u6cd5\u7ea7\u522b\u8981\u5355\u72ec\u7528@ResponseBody</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/4_2/#requestmapping","title":"RequestMapping","text":"<p>\u662f\u4ec0\u4e48\uff1a\u5b9a\u4e49\u8def\u7531\u89c4\u5219\uff0c\u628aURL\u5730\u5740\u6620\u5c04\u5230\u5bf9\u5e94\u7684\u5904\u7406\u65b9\u6cd5 \u4e3a\u4ec0\u4e48\u9700\u8981\u5b83\uff1a\u63a5\u53d7\u8bf7\u6c42\uff0c\u7b80\u4fbf\u4e0b\u9762\u8bf7\u6c42\u8def\u5f84 \u5751\u70b9\uff1a\u52a0\u5728\u7c7b\u4e0a\u662f\u7edf\u4e00\u524d\u7f00\uff0c\u52a0\u5728\u65b9\u6cd5\u4e0a\u662f\u5177\u4f53\u8def\u5f84\uff0c\u4e24\u5c42\u53e0\u52a0</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/","title":"\u7b14\u8bb0","text":""},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#gc","title":"GC","text":"<p>\u662f\u4ec0\u4e48 \u5728\u5355\u589e\u7684\u8fc7\u7a0b\u4e2d\u662fyoung gen\u751f\u6210\u7684\u8fc7\u7a0b\uff0c\u90a3\u4e2a\u65ad\u5d16\u5f0f\u4e0b\u8dcc\u5c31\u662fGC\u89e6\u53d1\u628a\u6240\u6709young gen\u90fd\u6e05\u7406\u6389\u4e86 \u4e3a\u4ec0\u4e48\u9700\u8981 \u5806\u5185\u5b58\u662f\u6709\u9650\u5236\u7684\uff0c\u6ee1\u4e86\u5c31\u4f1a\u5361\u4f4f\uff0c\u6240\u4ee5\u9700\u8981\u628a\u4e00\u4e9b\u7528\u4e0d\u5230\u7684\u5783\u573e\u7ed9\u6e05\u7406\u6389 \u5751\u70b9 \u5728GC\u8fc7\u7a0b\u4e2d\u4f1a\u89e6\u53d1STW\uff0c\u6574\u4e2a\u7a0b\u5e8f\u4f1a\u505c\u6b62\u6267\u884c\uff0c\u8fd9\u4e2a\u8fc7\u7a0b\u7684\u5feb\u6162\u5f80\u5f80\u51b3\u5b9a\u7740\u7a0b\u5e8f\u8fd0\u884c\u901f\u5ea6(\u8fd9\u91cc\u9762\u7684\u7406\u89e3\u6838\u5fc3\u5176\u5b9e\u8981\u4e86\u89e3\u5806\uff0c\u5b83\u4f1a\u626b\u63cf\u5806\uff0c\u5728\u5806\u91cc\u4f46\u6ca1\u4eba\u5f15\u7528\u7684\u5bf9\u8c61\u4f1a\u88ab\u6e05\u7406\u6389\uff0c\u66f4\u6df1\u4e00\u6b65\u53bb\u4e86\u89e3\u5c31\u662f\u53ef\u8fbe\u6027\u5206\u6790\u4e86\uff08Reachability Analysis\uff09)</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#exception","title":"exception \u5904\u7406","text":"<p>\u662f\u4ec0\u4e48  \u5c06\u5177\u4f53\u662f\u4ec0\u4e48\u9519\u8bef\u6b63\u786e\u663e\u793a\u5728\u63a7\u5236\u53f0\u548c\u5ba2\u6237\u7aef  \u4e3a\u4ec0\u4e48\u9700\u8981  \u628a\u670d\u52a1\u5668\u5185\u90e8\u5f02\u5e38\u7ffb\u8bd1\u6210\u5ba2\u6237\u7aef\u80fd\u7406\u89e3\u7684 HTTP \u8bed\u4e49  \u5751\u70b9 \u5f02\u5e38\u8981\u7ee7\u627f RuntimeException\uff0c\u5426\u5219\u6bcf\u4e2a\u65b9\u6cd5\u90fd\u8981\u663e\u5f0f\u58f0\u660e throws\uff0c\u4ee3\u7801\u5f88\u810f</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#virtual-threads","title":"Virtual Threads","text":""},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_1","title":"\u81ea\u5b9a\u4e49\u538b\u6d4b\u5de5\u5177\u5931\u8d25\u539f\u56e0","text":"<p>HttpClient\u4f7f\u7528\u5185\u90e8\u7ebf\u7a0b\u6c60\u5904\u7406\u8bf7\u6c42\uff0csend()\u540c\u6b65\u963b\u585e\u5bfc\u81f4\u538b\u6d4b\u65f6\u7ebf\u7a0b\u884c\u4e3a\u88ab\u5e72\u6270\uff0c\u5b9e\u9645\u9a8c\u8bc1\u6539\u7528\u65e5\u5fd7\u7ebf\u7a0b\u540d\u5bf9\u6bd4\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_2","title":"\u865a\u62df\u7ebf\u7a0b\u5f00\u542f\u4e0e\u5426\u7684\u5bf9\u6bd4","text":"<p>1.\u5173\u95ed\u865a\u62df\u7ebf\u7a0b\u65f6\u662f\u7528\u7684\u7ebf\u7a0b\u6c60\u91cc\u7684\u7ebf\u7a0b\uff0c 2.\u8bf7\u6c42\u6765\u4e86\u4f1a\u521b\u5efa\u865a\u62df\u7ebf\u7a0b\uff0c\u4f46\u865a\u62df\u7ebf\u7a0b\u8dd1\u5728\u5c11\u91cf\u56fa\u5b9a\u7684carrier threads\u4e0a\uff0c\u4e0d\u662f\u72ec\u5360\u4e00\u4e2a\u5e73\u53f0\u7ebf\u7a0b\u3002 3.\u865a\u62df\u7ebf\u7a0b\u5728\u7b49\u5f85\u65f6\u4f1a\u4ece\u627f\u8f7d\u7ebf\u7a0b\u4e0a\u4e0b\u6765\uff0c\u7b49\u5230\u597d\u4e86\u5c31\u4f1a\u91cd\u65b0\u6302\u8f7d\u5230\u627f\u8f7d\u7ebf\u7a0b\u3002\u800c\u5173\u95ed\u65f6\u7ebf\u7a0b\u4f1a\u4e00\u76f4\u5728\u627f\u8f7d\u7ebf\u7a0b\u4e0a\u9762\u7b49\u7740</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_3","title":"\u865a\u62df\u7ebf\u7a0b\u5f00\u542f\u65f6","text":""},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_4","title":"\u865a\u62df\u7ebf\u7a0b\u5173\u95ed\u65f6","text":""},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#o1","title":"\u54c8\u5e0c\u51fd\u6570\u4e3a\u4ec0\u4e48O(1)?","text":"<p>\u7ecf\u8fc7\u54c8\u5e0c\u51fd\u6570\u7684\u8ba1\u7b97\uff0c\u518d\u8fdb\u884c\u53d6\u6a21\uff0c\u539f\u6765\u7684key\u4f1a\u53d8\u4e3a\u5728\u4e00\u5b9a\u8303\u56f4\u5185\u7684\u6574\u6570\uff0c\u800c\u4e14\u8fd9\u4e2a\u6574\u6570\u7ecf\u8fc7\u8fd9\u4e2a\u51fd\u6570\u8ba1\u7b97\u5e76\u53d6\u6a21\u540e\u662f\u786e\u5b9a\u7684\uff0c\u56e0\u6b64\u53ef\u4ee5\u7528\u5176\u4f5c\u4e3a\u4e0b\u6807\uff0c\u6240\u4ee5\u67e5\u8be2\u901f\u5ea6\u63a5\u8fd1O\uff081\uff09</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_5","title":"\u54c8\u5e0c\u51b2\u7a81\uff1f","text":"<p>\u4e3a\u4e86\u89e3\u51b3\u591a\u4e2akey\u7ecf\u8fc7\u8ba1\u7b97\u5e76\u53d6\u6a21\u540e\u5f97\u5230\u76f8\u540c\u7684\u7ed3\u679c\uff0c\u6700\u540e\u4f1a\u5728\u540c\u4e00\u4e2a\u6876\u91cc\u9762\uff0c\u8fd9\u91cc\u91c7\u53d6\u94fe\u8868\u6765\u89e3\u51b3\uff0c\u76f8\u540c\u7684\u5c31\u7ee7\u7eed\u6302\u5728\u540e\u9762</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_6","title":"\u94fe\u8868\u592a\u957f\uff1f","text":"<p>\u5f53\u6570\u7ec4\u957f\u5ea6\u5c0f\u4e8e64\u4e14\u94fe\u8868\u957f\u5ea6\u5927\u4e8e8\u65f6\u4f1a\u5148\u91c7\u53d6\u6570\u7ec4\u6269\u5bb9\u7684\u65b9\u6cd5\uff0c\u6765\u7f29\u77ed\u94fe\u8868\u7684\u957f\u5ea6\uff0c\u5982\u679c\u6570\u7ec4\u5927\u4e8e\u7b49\u4e8e64\u4e14\u94fe\u8868\u957f\u5ea6\u5927\u4e8e8\u65f6\uff0c\u94fe\u8868\u8fd8\u662f\u592a\u957f\u5c31\u91c7\u53d6\u7ea2\u9ed1\u6811\u4ee3\u66ff\u94fe\u8868</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_7","title":"\u7ebf\u7a0b\u4e0d\u5b89\u5168\uff1f","text":"<p>\u5f53\u6269\u5bb9\u6570\u7ec4\u65f6\uff0cJava7\u91c7\u53d6\u5934\u63d2\u6cd5\u8fdb\u884c\u91cd\u65b0\u6392\u5217\u94fe\u8868\uff0c\u591a\u4e2a\u7ebf\u7a0b\u540c\u65f6\u64cd\u4f5c\uff0c\u8fd9\u91cc\u5c31\u6709\u53ef\u80fd\u51fa\u73b0\uff0c\u8282\u70b9\u7684next\u6307\u9488\u4e92\u76f8\u6307\u5411\uff0c\u5f62\u6210\u73af\u5f62\u94fe\u8868\uff0cCPU\u8bf7\u6c42\u76f4\u63a5\u5e72\u70e7\u3002</p> <p>Java8\u91c7\u53d6\u4e86\u5c3e\u63d2\u6cd5\uff0c\u4f46\u4f9d\u65e7\u6ca1\u80fd\u89e3\u51b3\u8282\u70b9\u8986\u76d6\u7684\u95ee\u9898\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_8","title":"\u6269\u5bb9\u4e3a\u5565\u8981\u91cd\u65b0\u63d2\u6bcf\u4e2a\u8282\u70b9\uff1f","text":"<p>\u56e0\u4e3a\u6269\u5bb9\u540e\uff0ckey\u7ecf\u8fc7\u54c8\u5e0c\u8ba1\u7b97\u540e\u5728\u8fdb\u884c\u53d6\u6a21\u53ef\u80fd\u4f1a\u5f97\u5230\u4e0d\u540c\u7684\u4e0b\u6807\uff0c\u6bcf\u4e2a\u6876\u91cc\u9762\u7684\u8282\u70b9\u90fd\u53ef\u80fd\u53bb\u65b0\u7684\u6876\u91cc\u9762</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_9","title":"\u6269\u5bb9\u89e6\u53d1\u6761\u4ef6(\u4e24\u79cd)","text":"<ol> <li> <p>\u5f53\u8d1f\u8f7d\u56e0\u5b50\u5927\u4e8e0.75\u65f6</p> </li> <li> <p>\u5f53\u6570\u7ec4\u957f\u5ea6\u5c0f\u4e8e64\u4e14\u94fe\u8868\u957f\u5ea6\u5927\u4e8e8\u65f6</p> </li> </ol>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#2","title":"\u4e3a\u4ec0\u4e48\u662f2\u500d","text":"<p>\u53ef\u4ee5\u5c06\u53d6\u6a21\u8fd0\u7b97\u4f18\u5316\u4e3a\u4f4d\u8fd0\u7b97\uff0chash % length \u4f18\u5316\u4e3a hash &amp; (length - 1)\uff0c\u53ea\u6709length\u662f2\u7684\u5e42\u6b21\u65f6\u7b49\u4ef7\uff0c\u62692\u500d\u4fdd\u8bc1\u6c38\u8fdc\u662f2\u7684\u5e42\u6b21</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#concurrenthashmap-cascompare-and-swap-synchronized","title":"ConcurrentHashMap: CAS\uff08compare and swap\uff09 + synchronized\u5206\u522b\u7528\u5728\u4ec0\u4e48\u573a\u666f","text":"<p>CAS\u7528\u5728\u51b2\u7a81\u8f83\u5c11\u65f6\uff0csynchronized\u7528\u5728\u51b2\u7a81\u8f83\u591a\u65f6</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#arraylistlinkedlist","title":"ArrayList\u548cLinkedList\u5e95\u5c42\u5206\u522b\u662f\u4ec0\u4e48\uff0c\u5404\u81ea\u4ec0\u4e48\u573a\u666f\u7528","text":"<p>ArrayList\u7684\u5e95\u5c42\u662f\u52a8\u6001\u6269\u5bb9\u7684\u6570\u7ec4\uff0c\u6bcf\u6b21\u6269\u59271.5\u500d,\u6269\u5bb9\u662f\u901a\u8fc7\u6d45\u62f7\u8d1d\u8fdb\u884c\u6269\u5bb9\u7684\uff0c\u590d\u5236\u7684\u662f\u6570\u7ec4\u7684\u5730\u5740\u3002\u5728\u8bfb\u591a\uff0c\u5199\u5c11\u7684\u60c5\u51b5\u4e0b\u6bd4\u8f83\u9002\u5408\u7528\u3002LinkedList\u662f\u7528\u6307\u9488\u6765\u6307\u5411\u5176\u4ed6\u8282\u70b9\u7684\u94fe\u8868\u3002\u9002\u5408\u5199\u591a\u8bfb\u5c11\u7684\u60c5\u51b5\u7528\uff0c\u4e2d\u95f4\u63d2\u5165\u7406\u8bba\u4e0aO(1)\uff0c\u4f46\u627e\u4f4d\u7f6e\u8fd8\u662fO(n)\uff0c\u5b9e\u9645\u4e0a\u603b\u4ee3\u4ef7O(n)</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#fail-fast","title":"fail-fast\u662f\u4ec0\u4e48\uff0c\u600e\u4e48\u89e6\u53d1\uff0c\u600e\u4e48\u907f\u514d","text":"<p>fail-fast\u662f\u8fed\u4ee3\u5668\u91cc\u9762\u7528\u6765\u5224\u65ad\u904d\u5386\u65f6\u662f\u5426\u5217\u8868\u6709\u88ab\u4fee\u6539\uff0c\u5982\u679c\u6709\u5c31\u76f4\u63a5\u629bConcurrentModificationException\uff0c\u7a0b\u5e8f\u76f4\u63a5\u5d29\uff0c\u6ca1\u6709\u5c31\u7ee7\u7eed\u3002\u901a\u8fc7\u7684\u662f\u4e00\u4e2a\u8bb0\u5f55\u88ab\u4fee\u6539\u6b21\u6570\u7684\u53d8\u91cfmodCount\uff0c\u8fd8\u6709\u53e6\u5916\u4e00\u4e2a\u53d8\u91cfexpectedModCount\u6765\u6bd4\u5bf9\u3002\u901a\u8fc7\u7528\u8fed\u4ee3\u5668\u91cc\u9762\u7684\u81ea\u5e26\u7684\u64cd\u4f5c\u53ef\u4ee5\u907f\u514d\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#for","title":"\u666e\u901afor\u5faa\u73af\u904d\u5386\u5220\u9664\u6709\u4ec0\u4e48\u5751","text":"<p>\u5220\u9664\u540e\u540e\u9762\u7684\u5143\u7d20index\u524d\u79fb\uff0c\u4e0b\u4e00\u6b21\u5faa\u73af\u8df3\u8fc7\u4e86\uff0c\u4f1a\u5bfc\u81f4\u6f0f\u6389\u4e00\u4e9b\u5143\u7d20</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#threadblockedwaiting","title":"Thread\u516d\u79cd\u72b6\u6001\uff0cBLOCKED\u548cWAITING\u7684\u533a\u522b","text":"<p>NEW, RUNNABLE, WAITING, BLOCKED, TIMED_WAITING, TERMINATED. BLOCKED\u548cWAITING\u7684\u533a\u522b\u662f\u4e00\u4e2a\u662f\u88ab\u52a8\u7684\u7b49\u5f85\uff0c\u4e00\u4e2a\u662f\u4e3b\u52a8\u7684\u7b49\u5f85notify()\u5524\u9192\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#synchronized","title":"synchronized\u9501\u7684\u662f\u4ec0\u4e48","text":"<p>\u5b9e\u4f8b\u65b9\u6cd5\uff1a\u9501\u7684\u662fthis\uff08\u5f53\u524d\u5bf9\u8c61\u5b9e\u4f8b\uff09\uff0c\u9759\u6001\u65b9\u6cd5\uff1a\u9501\u7684\u662fClass\u5bf9\u8c61\uff0c\u4ee3\u7801\u5757\uff1a\u9501\u7684\u662f\u62ec\u53f7\u91cc\u7684\u5bf9\u8c61</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_10","title":"\u53ef\u91cd\u5165\u662f\u4ec0\u4e48\uff0c\u4e3a\u4ec0\u4e48\u9700\u8981\u53ef\u91cd\u5165","text":"<p>\u53ef\u91cd\u5165\u662f\u540c\u4e00\u4e2a\u7ebf\u7a0b\u7ee7\u7eed\u7528\u540c\u4e00\u4e2a\u9501\uff0c\u5982\u679c\u4e0d\u80fd\u91cd\u5165\u5c31\u4f1a\u5bfc\u81f4\u7ebf\u7a0b\u628a\u81ea\u5df1\u9501\u6b7b\u3002Monitor\u5185\u90e8\u6709\u8ba1\u6570\u5668\uff0c\u91cd\u5165+1\uff0c\u9000\u51fa-1\uff0c\u5f52\u96f6\u624d\u91ca\u653e\u9501\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_11","title":"\u53ef\u89c1\u6027\u95ee\u9898\u662f\u4ec0\u4e48\uff0c\u4e3a\u4ec0\u4e48\u4f1a\u51fa\u73b0","text":"<p>cpu\u6709\u7f13\u5b58\uff0c\u5de5\u4f5c\u5185\u5b58\uff0c\u4fee\u6539\u540e\u4e0d\u4e00\u5b9a\u7acb\u523b\u540c\u6b65\uff0c\u6240\u4ee5\u4e00\u4e2a\u7ebf\u7a0b\u4fee\u6539\u4e86\u53d8\u91cf\uff0c\u53e6\u4e00\u4e2a\u7ebf\u7a0b\u53ef\u80fd\u6c38\u8fdc\u770b\u4e0d\u5230</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#volatile","title":"volatile\u89e3\u51b3\u4e86\u54ea\u4e24\u4e2a\u95ee\u9898\uff0c\u4e0d\u80fd\u89e3\u51b3\u4ec0\u4e48","text":"<p>\u53ef\u89c1\u6027\u95ee\u9898\uff0c\u7981\u6b62\u6307\u4ee4\u91cd\u6392\u5e8f\uff0c\u4e0d\u80fd\u89e3\u51b3\u539f\u5b50\u6027\u95ee\u9898</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#threadlocal","title":"ThreadLocal\u662f\u4ec0\u4e48\uff0c\u5185\u5b58\u6cc4\u6f0f\u600e\u4e48\u4ea7\u751f\uff0c\u600e\u4e48\u89e3\u51b3","text":"<p>\u662f\u6bcf\u4e2a\u7ebf\u7a0b\u5355\u72ec\u5b58\u4e00\u4efd\u6570\u636e\uff0c\u7ebf\u7a0b\u4e4b\u95f4\u76f8\u4e92\u9694\u79bb\uff0c\u7ebf\u7a0b\u6c60\u91cc\u7684\u7ebf\u7a0b\u4e0d\u53ef\u9500\u6bc1\uff0cvalue\u4e00\u76f4\u88abThreadLocalMap\u5f15\u7528\u7740\uff0c\u65e0\u6cd5GC\u56de\u6536\uff0c\u7528.remove()\u89e3\u51b3</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#happens-before","title":"happens-before\u662f\u4ec0\u4e48\uff0c\u8bf4\u51fa\u4e24\u6761\u89c4\u5219","text":"<p>JVM\u89c4\u5b9a\u7684\u7ebf\u7a0b\u4e4b\u95f4\u53ef\u89c1\u6027\u548c\u6709\u5e8f\u6027\u89c4\u5219\u3002\u4f20\u9012\u6027\u89c4\u5219\uff0cvolatile\u89c4\u5219\uff0c\u76d1\u89c6\u5668\u9501\u89c4\u5219\uff0c\u7a0b\u5e8f\u987a\u5e8f\u89c4\u5219</p> <ol> <li>\u6808\uff1a\u6bcf\u7ebf\u7a0b\u72ec\u4eab\uff0c\u5b58\u5c40\u90e8\u53d8\u91cf+\u64cd\u4f5c\u6570\u6808+\u8fd4\u56de\u5730\u5740\uff0c\u7206\u4e86\u2192StackOverflowError</li> <li>\u5806\uff1a\u7ebf\u7a0b\u5171\u4eab\uff0c\u5b58\u5bf9\u8c61\u5b9e\u4f8b+\u5b9e\u4f8b\u5b57\u6bb5\uff0c\u65e0\u5f15\u7528\u5bf9\u8c61\u7b49GC\u56de\u6536</li> <li>\u65b9\u6cd5\u533a\uff1a\u7ebf\u7a0b\u5171\u4eab\uff0c\u5b58\u7c7b\u4fe1\u606f+\u9759\u6001\u53d8\u91cf+\u5e38\u91cf\u6c60+\u65b9\u6cd5\u5b57\u8282\u7801</li> <li>\u6c38\u4e45\u4ee3\u2192\u5143\u7a7a\u95f4\uff1a\u4eceJVM\u56fa\u5b9a\u5185\u5b58\u2192\u672c\u5730\u5185\u5b58\uff0c\u4e0a\u9650\u4ece\u56fa\u5b9a\u53d8\u52a8\u6001</li> <li> <p>\u5c40\u90e8\u53d8\u91cf\u5728\u6808\uff0c\u5b9e\u4f8b\u5b57\u6bb5\u5728\u5806\uff0c\u9759\u6001\u53d8\u91cf\u5728\u65b9\u6cd5\u533a</p> </li> <li> <p>\u6807\u8bb0-\u6e05\u9664\uff1a\u6807\u8bb0\u5b58\u6d3b\u2192\u6e05\u9664\u5783\u573e\uff0c\u6709\u5185\u5b58\u788e\u7247\uff0c\u53ef\u80fd\u5bfc\u81f4OOM</p> </li> <li>\u590d\u5236\u7b97\u6cd5\uff1a\u5185\u5b58\u4e00\u5206\u4e3a\u4e8c\uff0c\u5b58\u6d3b\u5bf9\u8c61\u590d\u5236\u5230\u53e6\u4e00\u534a\uff0c\u65e0\u788e\u7247\u4f46\u5229\u7528\u738750%</li> <li>\u6807\u8bb0-\u6574\u7406\uff1a\u5b58\u6d3b\u5bf9\u8c61\u63a8\u5230\u4e00\u7aef\uff0c\u6574\u4f53\u6e05\u7a7a\u53e6\u4e00\u7aef\uff0c\u65e0\u788e\u7247+\u5229\u7528\u7387100%\u4f46\u6700\u6162</li> <li>\u5e74\u8f7b\u4ee3\u7528\u590d\u5236\uff1a\u5b58\u6d3b\u7387\u4f4e\uff0c\u590d\u5236\u5f00\u9500\u5c0f\uff0c\u65e0\u788e\u7247</li> <li>\u8001\u5e74\u4ee3\u7528\u6807\u8bb0-\u6574\u7406\uff1a\u5b58\u6d3b\u7387\u9ad8\uff0c\u9700\u8981100%\u5229\u7528\u7387+\u65e0\u788e\u7247\u9632\u5927\u5bf9\u8c61OOM</li> </ol>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#5-vs","title":"\u7c7b\u52a0\u8f7d5\u6b65\u6d41\u7a0b\uff08\u51c6\u5907 vs \u521d\u59cb\u5316\u7684\u533a\u522b\uff09","text":"<p>loading -&gt; verification -&gt; preparation -&gt; resolution -&gt; initialization</p> <p>preparation\u548cinitialization\u7684\u533a\u522b\u662f,\u524d\u8005\u662f\u4e3a\u4e3a\u7c7b\u7684\u9759\u6001\u53d8\u91cf\u5206\u914d\u5185\u5b58\uff0c\u5e76\u8d4b\u9ed8\u8ba4\u503c\uff08int\u21920\uff0cString\u2192null\uff0cboolean\u2192false\uff09\uff0c\u540e\u8005\u521d\u59cb\u5316\u662f\u8d4b\u503c</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#classloader","title":"\u4e09\u4e2a ClassLoader \u5404\u7ba1\u4ec0\u4e48","text":"<p>BootstrapClassLoader\u7ba1\u7684\u662fjdk\u6838\u5fc3</p> <p>ExtClassLoader\u7ba1\u7684\u662fjdk\u6269\u5c55\u5e93\uff0cjavax.*\u8fd9\u7c7b</p> <p>AppClassLoader\u7ba1\u7684\u662f\u81ea\u5df1\u5199\u7684\u4ee3\u7801</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_12","title":"\u53cc\u4eb2\u59d4\u6d3e\u5b8c\u6574\u6d41\u7a0b\uff08\u4e00\u6b65\u6b65\uff09","text":"<p>\u6536\u5230\u4e86\u4efb\u52a1\uff0c\u81ea\u5df1\u5148\u4e0d\u5b8c\u6210\uff0c\u5148\u5f80\u7236\u52a0\u8f7d\u5668\u4e0a\u4f20\uff0c\u5148\u4e00\u76f4\u4f20\u5230\u6700\u9876\u7aef\uff0c\u6700\u5927\u7684\u7236\u52a0\u8f7d\u5668\u8981\u662f\u8ba4\u8bc6\u8fd9\u4e2a\u7c7b\u5c31\u52a0\u8f7d\uff0c\u8981\u662f\u4e0d\u8ba4\u8bc6\uff0c\u624d\u5f80\u4e0b\u9000\uff0c\u9000\u5230\u8c01\u8ba4\u8bc6\u8c01\u5c31\u52a0\u8f7d\uff0c\u7136\u540e\u628a\u7ed3\u679c\u539f\u8def\u8fd4\u56de\u3002\u5982\u679c\u6240\u6709\u7236\u52a0\u8f7d\u5668\u90fd\u4e0d\u8ba4\u8bc6\uff0c\u6700\u7ec8\u9000\u56deAppClassLoader\uff0c\u7531AppClassLoader\u52a0\u8f7d\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_13","title":"\u53cc\u4eb2\u59d4\u6d3e\u7684\u6838\u5fc3\u4f5c\u7528","text":"<p>\u9632\u6b62jdk\u6838\u5fc3\u5e93\u88ab\u7be1\u6539\uff0c\u4f18\u5148\u4f7f\u7528jdk\u6838\u5fc3\u5e93\u518d\u4f7f\u7528\u81ea\u5df1\u5b9a\u4e49\u7684\u7c7b</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_14","title":"\u600e\u4e48\u6253\u7834","text":"<p>\u7ee7\u627fClassLoader+\u91cd\u5199loadClass\u65b9\u6cd5\uff0c\u53bb\u6389\u91cc\u9762\u59d4\u6d3e\u7236\u52a0\u8f7d\u5668\u7684\u903b\u8f91</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#iocinversion-of-control","title":"IoC(inversion of control)\u89e3\u51b3\u4e86\u4ec0\u4e48\u95ee\u9898","text":"<p>IoC\u628a\u5bf9\u8c61\u7684\u521b\u5efa\u548c\u6ce8\u5165\u63a7\u5236\u6743\u4ea4\u7ed9\u4e86\u5bb9\u5668\uff0cService\u53ea\u58f0\u660e\u9700\u8981\u4ec0\u4e48\uff0c\u5177\u4f53\u9700\u8981\u585e\u8c01\u7531\u5bb9\u5668\u51b3\u5b9a\u2014\u2014\u6240\u4ee5\u4f9d\u8d56\u53ef\u4ee5\u66ff\u6362\uff0c\u8026\u5408\u95ee\u9898\u89e3\u51b3\u4e86\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#bean5","title":"Bean\u751f\u547d\u5468\u671f5\u6b65","text":"<ol> <li>\u521b\u5efa\u5b9e\u4f8b\uff1a\u901a\u8fc7\u6784\u9020\u5668\u5148\u521b\u5efa\u4e00\u4e2a\u5bf9\u8c61</li> <li>\u6ce8\u5165\uff1a@Autowired\u628a\u4f9d\u8d56\u585e\u8fdb\u6765</li> <li>\u521d\u59cb\u5316\uff1a@PostConstruct\u6267\u884c\uff0c\u5728\u6ce8\u5165\u5b8c\u6210\u540e\u505a\u7684\u51c6\u5907\u5de5\u4f5c</li> <li>\u4f7f\u7528\uff1a\u4e1a\u52a1\u4ee3\u7801\u5728\u8dd1</li> <li>\u9500\u6bc1\uff1a@PreDestroy\u6267\u884c\uff0c\u91ca\u653e\u81ea\u5df1\u6301\u6709\u7684\u8d44\u6e90</li> </ol>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#_15","title":"\u5faa\u73af\u4f9d\u8d56\u600e\u4e48\u89e3\u51b3","text":"<p>\u5148\u628a\u5bf9\u8c61\u521b\u5efa\u51fa\u6765\uff0c\u5148\u4e0d\u6ce8\u5165\u5b57\u6bb5\uff0c\u5bf9\u8c61\u5b9e\u4f8b\u5316\u5b8c\u7acb\u523b\u5b58\u8d77\u6765\uff0c\u6ce8\u5165\u9636\u6bb5\u9700\u8981\u5b83\u65f6\u5148\u628a\u534a\u6210\u54c1\u4ea4\u51fa\u53bb\uff0c\u7b49\u53cc\u65b9\u90fd\u6ce8\u5165\u5b8c\uff0c\u534a\u6210\u54c1\u81ea\u7136\u53d8\u6210\u5b8c\u6574\u54c1\u3002\u8fd9\u4e2a\u673a\u5236\u53eb\u4e09\u7ea7\u7f13\u5b58\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#aop","title":"AOP\u89e3\u51b3\u4ec0\u4e48\u95ee\u9898\uff08\u4e00\u53e5\u8bdd\uff09","text":"<p>\u516c\u5171\u903b\u8f91\uff08\u4e8b\u52a1/\u65e5\u5fd7/\u6743\u9650\u6821\u9a8c\uff09\u6563\u843d\u5728\u6bcf\u4e2a\u65b9\u6cd5\u91cc\uff0c\u6539\u9700\u6c42\u5c31\u6539\u6bcf\u4e2a\u65b9\u6cd5\u3002AOP\u628a\u8fd9\u4e9b\u903b\u8f91\u62bd\u5230\u5207\u9762\uff0c\u4e1a\u52a1\u4ee3\u7801\u96f6\u4fb5\u5165\u3002</p>"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#jdk-vs-cglib","title":"JDK\u4ee3\u7406 vs CGLIB\u533a\u522b\uff08\u4e00\u5f20\u8868\uff09","text":"JDK\u4ee3\u7406 CGLIB \u600e\u4e48\u4f2a\u88c5 \u5b9e\u73b0\u540c\u4e00\u4e2a\u63a5\u53e3 \u7ee7\u627f\u539f\u59cb\u7c7b\u751f\u6210\u5b50\u7c7b \u8981\u6c42 \u5fc5\u987b\u6709\u63a5\u53e3 \u4e0d\u9700\u8981\u63a5\u53e3 \u9650\u5236 \u6ca1\u63a5\u53e3\u6b47\u83dc <code>final</code>\u7c7b\u6b47\u83dc"},{"location":"%E9%A1%B9%E7%9B%AE%E7%AC%94%E8%AE%B0/%E7%AC%94%E8%AE%B0/#transactional","title":"<code>@Transactional</code>\u5931\u6548\u7684\u573a\u666f\u548c\u539f\u56e0","text":"<p>\u540c\u7c7b\u5185\u90e8\u7528<code>this</code>\u8c03\u7528\uff0c\u7ed5\u8fc7\u4ee3\u7406\u5bf9\u8c61\uff0cAOP\u5931\u6548\uff0c<code>@Transactional</code>\u4e0d\u751f\u6548.</p> <ol> <li>\u7d22\u5f15\u662f\u76ee\u5f55\uff0c\u89e3\u51b3\u5168\u8868\u626b\u63cf\u95ee\u9898\uff0c\u4ee3\u4ef7\u662f\u7a7a\u95f4+\u5199\u5165\u7ef4\u62a4</li> <li>B+\u6811\u5185\u90e8\u8282\u70b9\u53ea\u5b58\u65b9\u5411\u2192\u4e0a\u5343\u4e2a\u53c9\u21923-4\u5c42\u2192\u4e2a\u4f4d\u6570IO</li> <li>\u53f6\u5b50\u8282\u70b9\u94fe\u8868\u2192\u8303\u56f4\u67e5\u8be2\u6a2a\u626b</li> <li>\u4e0d\u7528BST\u21922\u4e2a\u53c9\u2192\u5c42\u6570\u7206\u70b8(\u51e0\u5341\u5c42)\u2192IO\u7206\u70b8</li> <li>\u8054\u5408\u7d22\u5f15\u6309\u5217\u987a\u5e8f\u7ec4\u7ec7\uff0c\u6700\u5de6\u524d\u7f00\u539f\u5219\uff0c\u8df3\u5217\u7d22\u5f15\u5931\u6548</li> </ol>"}]}